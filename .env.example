# Backend API base URL — no trailing slash
# During development, point this at your local server
# In production, point it at your deployed API (e.g. https://api.quicksenddelivery.com)
VITE_API_URL=http://localhost:3000

# Optional — must match ADMIN_SECRET in your backend .env
# If your backend sets ADMIN_SECRET, set the same value here so the
# x-admin-secret header is sent on every login request.
# Leave blank (or omit) if ADMIN_SECRET is not configured on the backend.
# VITE_ADMIN_SECRET=
